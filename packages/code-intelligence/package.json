{
  "name": "@catdaemon/pi-code-intelligence",
  "version": "0.1.8",
  "description": "Local codebase graph, semantic search, repo learnings, and review tools for Pi.",
  "type": "module",
  "keywords": ["pi-package", "pi", "code-intelligence", "code-review", "semantic-search"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Catdaemon/pi-extensions",
    "directory": "packages/code-intelligence"
  },
  "homepage": "https://github.com/Catdaemon/pi-extensions/tree/main/packages/code-intelligence#readme",
  "bugs": { "url": "https://github.com/Catdaemon/pi-extensions/issues" },
  "pi": { "extensions": ["./dist/index.ts"] },
  "files": ["dist", "README.md", "LICENSE", "package.json", "tsconfig.json"],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/tests/*.test.ts",
    "pack:dry-run": "npm run build && npm pack --dry-run --ignore-scripts",
    "prepack": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.45.2",
    "minimatch": "^10.2.5",
    "tsx": "^4.20.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
