{
  "name": "@catdaemon/pi-agent-todos",
  "version": "0.1.4",
  "description": "Conversation todo tools, prompt guidance, and status sidebar for Pi.",
  "type": "module",
  "keywords": ["pi-package", "pi", "todos", "agent-tools"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Catdaemon/pi-extensions",
    "directory": "packages/todos"
  },
  "homepage": "https://github.com/Catdaemon/pi-extensions/tree/main/packages/todos#readme",
  "bugs": { "url": "https://github.com/Catdaemon/pi-extensions/issues" },
  "pi": { "extensions": ["./dist/index.ts"] },
  "files": ["dist", "README.md", "LICENSE", "package.json", "tsconfig.json"],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/tests/*.test.ts",
    "pack:dry-run": "npm run build && npm pack --dry-run --ignore-scripts",
    "prepack": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
