{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@catdaemon/pi-sidebar": ["../sidebar/src/index.ts"]
    }
  },
  "include": ["index.ts", "src/**/*.ts", "../sidebar/src/index.ts"]
}
