{
  "name": "@catdaemon/pi-sidebar",
  "version": "0.1.1",
  "description": "Shared status-card sidebar helpers for Pi extensions.",
  "type": "module",
  "keywords": ["pi-package", "pi", "sidebar", "status-card"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Catdaemon/pi-extensions",
    "directory": "packages/sidebar"
  },
  "homepage": "https://github.com/Catdaemon/pi-extensions/tree/main/packages/sidebar#readme",
  "bugs": { "url": "https://github.com/Catdaemon/pi-extensions/issues" },
  "exports": {
    ".": "./index.ts"
  },
  "files": ["index.ts", "src", "README.md", "package.json", "tsconfig.json"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/tests/*.test.ts",
    "pack:dry-run": "npm pack --dry-run --ignore-scripts",
    "prepack": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  }
}
